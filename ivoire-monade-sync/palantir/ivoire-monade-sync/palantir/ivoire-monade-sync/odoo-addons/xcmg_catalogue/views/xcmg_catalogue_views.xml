<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_xcmg_catalogue_line_tree" model="ir.ui.view">
        <field name="name">xcmg.catalogue.line.tree</field>
        <field name="model">xcmg.catalogue.line</field>
        <field name="arch" type="xml">
            <tree string="XCMG Catalogue Lines">
                <field name="name"/>
                <field name="category"/>
                <field name="product_tmpl_id"/>
                <field name="active"/>
            </tree>
        </field>
    </record>
    <record id="view_xcmg_catalogue_line_form" model="ir.ui.view">
        <field name="name">xcmg.catalogue.line.form</field>
        <field name="model">xcmg.catalogue.line</field>
        <field name="arch" type="xml">
            <form string="XCMG Catalogue Line">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="category"/>
                        <field name="product_tmpl_id"/>
                        <field name="active"/>
                    </group>
                    <group>
                        <field name="spec_json"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_xcmg_catalogue_line" model="ir.actions.act_window">
        <field name="name">XCMG Catalogue</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">xcmg.catalogue.line</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_xcmg_catalogue_line_filter"/>
    </record>
    <record id="view_xcmg_catalogue_line_filter" model="ir.ui.view">
        <field name="name">xcmg.catalogue.line.search</field>
        <field name="model">xcmg.catalogue.line</field>
        <field name="arch" type="xml">
            <search string="Search XCMG Catalogue">
                <field name="name"/>
                <field name="category"/>
                <filter string="Active" name="active" domain="[('active','=',True)]"/>
            </search>
        </field>
    </record>
    <menuitem
        id="menu_xcmg_catalogue_root"
        name="XCMG"
        sequence="10"
        groups="base.group_user"
        action="action_xcmg_catalogue_line"
    />
</odoo>
